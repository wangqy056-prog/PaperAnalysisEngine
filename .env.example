# Paper Analysis Engine - 环境变量配置
# 复制此文件为 .env 并填入你的 API Key

# ==================== LLM 模型 API Key ====================

# DeepSeek V4 Flash（主力模型）
# 申请地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Groq Llama 3.3 70B（高速免费模型，每天 1000 次请求）
# 申请地址：https://console.groq.com/
GROQ_API_KEY=

# 智谱 GLM-4-Flash（备用模型，完全免费）
# 申请地址：https://open.bigmodel.cn/
GLM_API_KEY=

# 当前使用的模型：deepseek / groq / glm
LLM_PROVIDER=deepseek

# ==================== 服务配置 ====================

# 后端服务端口
BACKEND_PORT=8001

# 前端服务端口
FRONTEND_PORT=5173

# 数据库路径（Docker 部署时无需修改）
DATABASE_PATH=backend/papers.db
